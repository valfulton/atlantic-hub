# Dependencies
/node_modules
/.pnp
.pnp.js

# Build output
/.next/
/out/
/build

# Production
/dist

# Misc
.DS_Store
*.pem
*.key
*.p12
*.pfx

# Environment files — NEVER commit
.env
.env*
!.env.example

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel / Netlify
.vercel
.netlify

# IDE
.vscode/
.idea/
.claude/

# TypeScript incremental build cache
tsconfig.tsbuildinfo
tsconfig.*.tsbuildinfo
*.tsbuildinfo

# OneDrive/FUSE filesystem placeholders — created when a process has a file
# open and OneDrive tries to delete/move it. They auto-clean when the holding
# process closes. Never real changes to commit.
.fuse_hidden*
**/.fuse_hidden*

# Secrets / credentials — NEVER commit
secrets.*
credentials.*
auth.*
*.secrets
.ssh/
/docs/
