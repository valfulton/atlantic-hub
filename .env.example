# =====================================================================
# Atlantic Hub — Environment variable template
# =====================================================================
# Copy this file to .env.local for LOCAL DEV ONLY.
# .env.local is gitignored and stays on your machine.
# Production values live in Netlify Site Environment Variables only.
#
# NEVER fill in real values here. NEVER commit a .env* file.
# =====================================================================

# --- Platform database (shhdbite_atlantic_hub) ---
DB_HOST=
DB_PORT=3306
DB_USER_PLATFORM=
DB_PASS_PLATFORM=
DB_NAME_PLATFORM=shhdbite_atlantic_hub

# --- HunterHoney tenant database (shhdbite_hunterhoney) ---
DB_USER_HH=
DB_PASS_HH=
DB_NAME_HH=shhdbite_hunterhoney

# --- Auth secrets ---
# JWT_SECRET: 32+ random bytes, base64. Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_ISSUER=atlantic-hub

# --- Data-at-rest encryption ---
# EMAIL_ENCRYPTION_KEY: 32 bytes, base64. Generate with: openssl rand -base64 32
EMAIL_ENCRYPTION_KEY=

# --- Hashing salts ---
# IP_SALT: 32 bytes, base64. Generate with: openssl rand -base64 32
IP_SALT=

# --- Webhook authentication ---
# NETLIFY_FORMS_WEBHOOK_SECRET: 32+ bytes, base64. Generate with: openssl rand -base64 48
NETLIFY_FORMS_WEBHOOK_SECRET=

# --- Owner bootstrap ---
# OWNER_BOOTSTRAP_EMAIL: the email of the first owner user
OWNER_BOOTSTRAP_EMAIL=info@atlanticandvine.com
# OWNER_BOOTSTRAP_PASSWORD_HASH: bcrypt-12 hash. Generate with:
#   node scripts/generate-owner-hash.js
OWNER_BOOTSTRAP_PASSWORD_HASH=

# --- Runtime ---
NODE_ENV=production
