{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDirs": ["src", "../lib"],
    "baseUrl": "..",
    "paths": {
      "@/lib/*": ["lib/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "../lib/**/*.ts"],
  "exclude": ["node_modules", "dist", "../node_modules", "../app", "../components"]
}
