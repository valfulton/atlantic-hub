{
  "name": "atlantic-hub-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Heavy-AI-work backend for Atlantic Hub. Runs on HostGator's Node app manager so we are not bound by Netlify's 60s function timeout. Bulk refresh, score sweeps, pain sweeps land here.",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "smoke": "node dist/server.js --smoke"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mysql2": "^3.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
